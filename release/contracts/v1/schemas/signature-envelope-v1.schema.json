{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hoangnb24/repository-harness/release/contracts/v1/schemas/signature-envelope-v1.schema.json",
  "title": "Repository Harness detached signature envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "trust_domain", "role", "sequence", "payload_sha256", "signatures"],
  "properties": {
    "schema": {"const": "repository-harness-signature-envelope/v1"},
    "trust_domain": {"enum": ["repository-harness-core", "repository-harness-bridge"]},
    "role": {"type": "string"},
    "sequence": {"type": "integer", "minimum": 1},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key_id", "algorithm", "signature"],
        "properties": {
          "key_id": {"type": "string", "pattern": "^ed25519-sha256:[0-9a-f]{64}$"},
          "algorithm": {"const": "ed25519"},
          "signature": {"type": "string"}
        }
      }
    }
  }
}
