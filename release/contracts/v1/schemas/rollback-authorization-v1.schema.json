{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hoangnb24/repository-harness/release/contracts/v1/schemas/rollback-authorization-v1.schema.json",
  "title": "Repository Harness root rollback authorization",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "trust_domain", "root_bundle_sequence", "role", "authorized_sequence", "authorized_digest"],
  "properties": {
    "schema": {"const": "repository-harness-rollback-authorization/v1"},
    "trust_domain": {"enum": ["repository-harness-core", "repository-harness-bridge"]},
    "root_bundle_sequence": {"type": "integer", "minimum": 1},
    "role": {"enum": ["core-release", "bridge-release"]},
    "authorized_sequence": {"type": "integer", "minimum": 1},
    "authorized_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
