{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hoangnb24/repository-harness/release/contracts/v1/schemas/command-implementation-binding-v1.schema.json",
  "title": "Repository Harness command implementation binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "binding_state", "grammar_contract", "grammar_contract_sha256", "grammar_schema", "grammar_schema_sha256", "surfaces"],
  "properties": {
    "schema": {"const": "repository-harness-command-implementation-binding/v1"},
    "binding_state": {"const": "core-live-bridge-absent"},
    "grammar_contract": {"const": "release/contracts/v1/command-grammars.json"},
    "grammar_contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "grammar_schema": {"const": "release/contracts/v1/schemas/command-grammar-v1.schema.json"},
    "grammar_schema_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core", "bridge"],
      "properties": {
        "core": {"$ref": "#/$defs/core_surface"},
        "bridge": {"$ref": "#/$defs/bridge_surface"}
      }
    }
  },
  "$defs": {
    "core_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "entrypoints", "entrypoint_state", "live_binding"],
      "properties": {
        "phase": {"const": 2},
        "entrypoints": {"const": ["scripts/bin/harness", "scripts/bin/harness.exe"]},
        "entrypoint_state": {"const": "live-platform-native"},
        "live_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["native_cli", "windows_cli", "cargo_package", "cargo_binary", "source_command_definitions", "help_argument", "requirements"],
          "properties": {
            "native_cli": {"const": "scripts/bin/harness"},
            "windows_cli": {"const": "scripts/bin/harness.exe"},
            "cargo_package": {"const": "harness-core"},
            "cargo_binary": {"const": "harness"},
            "source_command_definitions": {"const": "crates/harness-core/src/command_spec.rs"},
            "help_argument": {"const": "--help"},
            "requirements": {"const": ["platform-native-entrypoint-file-present", "live-cli-help-extraction-equals-command-grammars", "live-source-command-extraction-equals-command-grammars", "options-exits-and-mutation-boundaries-equal-command-grammars", "windows-cargo-binary-identity-is-harness.exe"]}
          }
        }
      }
    },
    "bridge_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["future_phase", "future_entrypoints", "entrypoint_state", "live_binding_gate"],
      "properties": {
        "future_phase": {"const": 4},
        "future_entrypoints": {"const": ["scripts/bin/harness-v0-migrate", "scripts/bin/harness-v0-migrate.exe"]},
        "entrypoint_state": {"const": "absent"},
        "live_binding_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase_acceptance", "replacement_state", "requirements"],
          "properties": {
            "phase_acceptance": {"const": "required-before-phase-4-acceptance"},
            "replacement_state": {"const": "live-cli-and-source-extraction-parity"},
            "requirements": {"const": ["future-entrypoint-files-present", "live-cli-help-extraction-equals-command-grammars", "live-source-command-extraction-equals-command-grammars", "options-exits-and-mutation-boundaries-equal-command-grammars"]}
          }
        }
      }
    }
  }
}
