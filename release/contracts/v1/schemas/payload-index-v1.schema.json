{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hoangnb24/repository-harness/release/contracts/v1/schemas/payload-index-v1.schema.json",
  "title": "Repository Harness authenticated payload index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "trust_domain", "role", "sequence", "release", "source_commit", "tag", "assets"],
  "properties": {
    "schema": {"enum": ["repository-harness-payload-index/v1", "repository-harness-bridge-payload-index/v1"]},
    "trust_domain": {"enum": ["repository-harness-core", "repository-harness-bridge"]},
    "role": {"enum": ["core-release", "bridge-release"]},
    "sequence": {"type": "integer", "minimum": 1},
    "release": {"type": "string"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tag": {"type": "string"},
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "sha256", "bytes", "disposition", "destination"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "source": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0},
          "disposition": {"enum": ["managed-v1", "optional-v1", "bridge-only-legacy"]},
          "destination": {"type": "string"},
          "role": {"type": "string"},
          "template": {"type": "string"}
        }
      }
    }
  }
}
