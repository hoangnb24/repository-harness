{
  "schema": "repository-harness-compatibility/v1",
  "decision": "docs/decisions/0012-v0-compatibility-window-and-retention.md",
  "security_decision": "docs/decisions/0013-v1-security-and-v0-capture-contract.md",
  "compatibility_window": {
    "start": "2027-01-01T00:00:00Z",
    "end_inclusive": "2027-12-31T23:59:59Z",
    "minimum_supported_days_if_shifted": 365
  },
  "local_archives": {
    "retention": "indefinite",
    "custody": "repository-owner",
    "automatic_delete_overwrite_truncate_relocate": false,
    "default_confidentiality": "encrypted-age-x25519",
    "plaintext_requires": ["--archive-plaintext", "--acknowledge-plaintext-recovery-risk"]
  },
  "bridge_assets": {
    "retained_through_inclusive": "2028-06-30T23:59:59Z",
    "availability_check_max_interval_days": 7,
    "signed_receipt_interval": "calendar-month",
    "receipt_threshold": "2-of-3-bridge-release",
    "supported_platforms": ["macos-arm64", "macos-x64", "linux-x64", "linux-arm64", "windows-x64"],
    "complete_set": ["binary-per-supported-platform", "checksum-per-binary", "authenticated-index-or-attestation", "supported-input-matrix", "release-notes", "source-tag", "reproducible-build-instructions"],
    "platform_scoped_categories": ["binary-per-supported-platform", "checksum-per-binary"]
  },
  "phase_8": {
    "eligible_no_earlier_than": "2028-01-01T00:00:00Z",
    "requires": ["phase-7-accepted", "authoritative-time-evidence", "support-and-recovery-obligations-closed", "no-unresolved-supported-range-security-data-loss-or-archive-integrity-defect", "bridge-assets-current-and-retained", "separate-removal-authorization", "separate-removal-validation", "local-archives-unchanged"]
  }
}
