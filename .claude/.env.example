# Copy to .claude/.env and fill in real values.
# .claude/.env is auto-loaded by .claude/hooks/telegram-notify.sh

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat/user ID. Quick way: message your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and copy `chat.id`.
TELEGRAM_CHAT_ID=

# Optional: 1 = silent message (no sound on phone). Default 0.
TELEGRAM_NOTIFY_SILENT=0

# Context monitor (.claude/hooks/context-monitor.sh). Match this to your
# model's actual context window so the % is meaningful.
# Default 1000000 (Opus 4.7 / Sonnet 4.6 1M tier). Use 200000 for legacy 200K.
CONTEXT_WINDOW_TOKENS=1000000

# Optional: 1 = suppress every context warning. Default 0.
CONTEXT_WARN_DISABLE=0
