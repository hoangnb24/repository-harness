{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness.dev/schemas/v1-phase6/packet-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packet_id", "pilot_id", "lane_id", "artifacts"],
  "properties": {
    "schema": {"const": "repository-harness-phase6-packet-manifest/v1"},
    "packet_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,127}$"},
    "pilot_id": {"type": "string", "minLength": 1},
    "lane_id": {"type": "string", "minLength": 1},
    "artifacts": {"type": "array", "minItems": 5, "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "media_type", "purpose", "visibility"], "properties": {"path": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+$"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "media_type": {"type": "string", "minLength": 1}, "purpose": {"type": "string", "minLength": 1}, "visibility": {"enum": ["agent-visible", "evaluator-only", "public-evidence"]}}}}
  }
}
