{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness.dev/schemas/v1-phase6/signature.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "owner_id", "algorithm", "namespace", "statement", "signature"],
  "properties": {
    "schema": {"const": "repository-harness-phase6-packet-authentication/v1"},
    "owner_id": {"type": "string", "minLength": 1},
    "algorithm": {"const": "ssh-ed25519"},
    "namespace": {"const": "repository-harness-phase6"},
    "statement": {"type": "object", "additionalProperties": false, "required": ["schema", "packet_id", "pilot_id", "canonical_repository", "lane_id", "packet_manifest_sha256", "condition_identity_sha256", "subject_identity_sha256", "result_sha256", "comparison_sha256", "completed_at", "published_at"], "properties": {"schema": {"const": "repository-harness-phase6-authenticated-result/v1"}, "packet_id": {"type": "string", "minLength": 1}, "pilot_id": {"type": "string", "minLength": 1}, "canonical_repository": {"type": "string", "pattern": "^https://[A-Za-z0-9.-]+/[A-Za-z0-9._/-]+[.]git$"}, "lane_id": {"type": "string", "minLength": 1}, "packet_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "condition_identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "subject_identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "result_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "comparison_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "completed_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}, "published_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}}},
    "signature": {"type": "string", "minLength": 1}
  }
}
