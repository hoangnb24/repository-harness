{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness.dev/schemas/v1-phase5/environment-lock.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "pilot_id", "model", "reasoning", "operating_system", "architecture", "tools", "enabled_tools", "permissions", "evaluator", "fixtures", "acceptance_commands", "environment_sha256"],
  "properties": {
    "schema": {"const": "repository-harness-environment-lock/v1"}, "pilot_id": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1}, "reasoning": {"type": "string", "minLength": 1},
    "operating_system": {"type": "string", "minLength": 1}, "architecture": {"type": "string", "minLength": 1},
    "tools": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["name", "version"], "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}}},
    "enabled_tools": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "permissions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evaluator": {"type": "string", "minLength": 1},
    "fixtures": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}},
    "acceptance_commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "environment_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
