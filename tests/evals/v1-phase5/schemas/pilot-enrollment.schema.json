{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness.dev/schemas/v1-phase5/pilot-enrollment.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "pilot_id", "canonical_repository", "owner_id", "authorization_scope", "authorized_at", "starting_revision", "card_set_sha256"],
  "properties": {
    "schema": {"const": "repository-harness-pilot-enrollment/v2"},
    "pilot_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "canonical_repository": {"type": "string", "pattern": "^https://[a-z0-9.-]+/[A-Za-z0-9._/-]+[.]git$"},
    "owner_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "authorization_scope": {"type": "string", "minLength": 1},
    "authorized_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "starting_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value", "repository_bundle"],
      "properties": {
        "kind": {"const": "git-commit"},
        "value": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "repository_bundle": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+$"}
      }
    },
    "card_set_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
