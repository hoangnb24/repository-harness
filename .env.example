# Copy to .env and fill in OPENAI_API_KEY to enable the real optional L4 provider.
# The profiler still requires --use-llm before any provider call is attempted.

VSF_PROFILER_LLM_PROVIDER=openai
OPENAI_API_KEY=

# Lower-cost OpenAI model shown in current OpenAI model docs; override if needed.
VSF_OPENAI_MODEL=gpt-5.4-mini
VSF_OPENAI_BASE_URL=https://api.openai.com/v1
VSF_OPENAI_TIMEOUT_SECONDS=60
VSF_OPENAI_MAX_OUTPUT_TOKENS=1200
